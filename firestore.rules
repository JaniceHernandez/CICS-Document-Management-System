rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CICS Docs Hub - Security Rules Documentation
     *
     * Core Philosophy: 
     * This ruleset enforces a strict role-based access model distinguishing between 'Students' and 'Admins'. 
     * Security is anchored in 'Existence over Content' for administrative privileges and 'Ownership' for 
     * student-generated data.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /adminRoles/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update: if isOwner(adminId) || isAdmin(); 
      allow delete: if isAdmin(); 
    }

    match /documents/{documentId} {
      allow get, list: if isSignedIn();
      // Allow students to submit documents
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if isAdmin();
      // Students need to update the downloadCount metadata or their own submissions
      allow update: if isSignedIn() && (
        isAdmin() || 
        resource.data.uploaderId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloadCount', 'updatedAt'])
      );
    }

    match /categories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /programs/{programId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin() || (isOwner(resource.data.studentId));
      allow delete: if isAdmin();
    }

    match /faqs/{faqId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /activityLogs/{activityLogId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /inquiryPeriods/{inquiryPeriodId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}