rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CICS Docs Hub - Security Rules Documentation
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@neu.edu.ph';
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid)) ||
        isSuperAdmin()
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // Only super admin can modify other admins or the super admin account itself.
      // Regular admins can only modify students.
      allow update: if isOwner(userId) || 
                    isSuperAdmin() || 
                    (isAdmin() && resource.data.role == 'Student' && resource.data.email != 'admin@neu.edu.ph');
      allow delete: if isSuperAdmin();
    }

    match /adminRoles/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow users to create their own role entry if they are the super admin or have been authorized
      allow create: if isOwner(adminId) || isSuperAdmin();
      allow update, delete: if isSuperAdmin(); 
    }

    match /authorizedAdmins/{emailId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Only the Super Admin can add or remove administrative clearances.
      allow write: if isSuperAdmin();
    }

    match /documents/{documentId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.uploaderId == request.auth.uid);
      allow update: if isSignedIn() && (
        isAdmin() || 
        resource.data.uploaderId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloadCount', 'updatedAt'])
      );
    }

    match /categories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /programs/{programId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin() || (isOwner(resource.data.studentId));
      allow delete: if isAdmin();
    }

    match /faqs/{faqId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /activityLogs/{activityLogId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /inquiryPeriods/{inquiryPeriodId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}